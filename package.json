{
  "name": "blockclock",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:standard": "VITE_LAYOUT=standard vp dev",
    "dev:slim": "VITE_LAYOUT=slim vp dev",
    "build": "pnpm run build:standard && pnpm run build:slim",
    "build:standard": "VITE_LAYOUT=standard vp build --emptyOutDir false && mv dist/index.html dist/dottokei-standard.html",
    "build:slim": "VITE_LAYOUT=slim vp build --emptyOutDir false && mv dist/index.html dist/dottokei-slim.html",
    "preview": "vp preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "prepare": "vp config",
    "package": "cd dist && zip -r dottokei.zip . -x \"*.DS_Store\" && cd .."
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^24.12.0",
    "svelte": "^5.53.7",
    "svelte-check": "^4.4.5",
    "typescript": "~5.9.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plugin-singlefile": "^2.3.2",
    "vite-plus": "latest"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  }
}